<!DOCTYPE html>
<html lang="vi" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VocaWebApp</title>
    <link rel="stylesheet" href="~/css/styles.css" asp-append-version="true" />
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@600&family=Inter:wght@400;500&display=swap" rel="stylesheet">
</head>
<body class="bg-gray-50 font-inter min-h-screen flex flex-col">
    <!-- Header -->
    <header class="bg-white shadow-lg">
        <div class="container mx-auto px-6 py-4">
            <div class="flex items-center justify-between">
                <!-- Logo và main navigation -->
                <div class="flex items-center space-x-8">
                    <span class="text-2xl font-poppins font-bold text-indigo-600">VocaWebApp</span>
                    <nav class="hidden md:flex space-x-6">
                        <a href="/" class="px-3 py-2 text-gray-700 hover:text-indigo-600 font-medium rounded-lg transition-all duration-300 hover:bg-indigo-50">
                            <i class="mr-2">🏠</i> Trang chủ
                        </a>
                        <a href="/mysets" class="px-3 py-2 text-gray-700 hover:text-indigo-600 font-medium rounded-lg transition-all duration-300 hover:bg-indigo-50">
                            <i class="mr-2">📚</i> Bộ từ vựng
                        </a>
                        <a href="/explore" class="px-3 py-2 text-gray-700 hover:text-indigo-600 font-medium rounded-lg transition-all duration-300 hover:bg-indigo-50">
                            <i class="mr-2">🌐</i> Khám phá
                        </a>
                    </nav>
                </div>
                <!-- User section đã tách ra partial -->
                <div class="flex items-center space-x-4">
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="flex-1 py-8">
        <div class="container mx-auto px-6">
            @RenderBody()
        </div>
    </main>

    <!-- Footer -->
    <footer class="bg-white border-t mt-8">
        <div class="container mx-auto px-6 py-4 text-center text-gray-500 text-sm">
            &copy; 2025 VocaWebApp - Hệ thống học từ vựng tiếng Anh thông minh
        </div>
    </footer>

    @RenderSection("Scripts", required: false)
</body>
</html>
