<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create New Set - Voca Web App</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Poppins:wght@700&display=swap" rel="stylesheet">
    <style>
        /* Applying fonts and focus ring from the UI Spec */
        body {
            font-family: 'Inter', sans-serif;
            background-color: #F9FAFB;
        }
        /* Nền: Gray-50  */
        h1, h2, h3, h4, h5, h6 {
            font-family: 'Poppins', sans-serif;
        }
        /* Font Heading: Poppins  */
        *:focus-visible {
            outline: 2px solid #FACC15;
            outline-offset: 2px;
            border-radius: 6px;
        }
        /* focus ring #FACC15  */
        /* Custom styling for radio buttons */
        .form-radio:checked {
            background-image: url("data:image/svg+xml,%3csvg viewBox='0 0 16 16' fill='white' xmlns='http://www.w3.org/2000/svg'%3e%3ccircle cx='8' cy='8' r='3'/%3e%3c/svg%3e");
            border-color: #4F46E5; /* Primary color */
            background-color: #4F46E5;
        }
    </style>
    <script>
        // Customizing Tailwind theme to match the UI Spec
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'primary': '#4F46E5',     // Indigo-600
                        'accent-pink': '#EC4899', // Pink-500
                        'accent-green': '#22C55E',// Green-500
                        'light-gray': '#F9FAFB'   // Gray-50
                    }
                }
            }
        }
    </script>
</head>
<body class="p-4 sm:p-6 lg:p-8">

    <div class="max-w-screen-md mx-auto">

        <header class="mb-8">
            <nav class="text-sm font-medium text-gray-500 mb-2">
                <a href="/dashboard" class="hover:text-primary">Dashboard</a>
                <span class="mx-2">/</span>
                <a href="/vocasets" class="hover:text-primary">My Sets</a>
                <span class="mx-2">/</span>
                <span class="text-gray-800">Create</span>
            </nav>
            <h1 class="text-3xl font-bold text-gray-800">Create a New Vocabulary Set</h1>
            <p class="text-gray-500 mt-1">Fill in the details below to start adding words.</p>
        </header>

        <form action="/vocasets/create" method="POST" class="bg-white p-8 rounded-2xl shadow-lg space-y-6">

            <div>
                <label for="set-name" class="block text-sm font-bold text-gray-700 mb-1">Set Name</label>
                <input type="text" id="set-name" placeholder="e.g. 'IELTS Academic Words'" class="w-full border border-gray-300 rounded-lg shadow-sm p-3 focus:ring-2 focus:ring-primary focus:border-primary transition">
            </div>

            <div>
                <label for="description" class="block text-sm font-bold text-gray-700 mb-1">Description (Optional)</label>
                <textarea id="description" rows="4" placeholder="A short summary of what this set is about." class="w-full border border-gray-300 rounded-lg shadow-sm p-3 focus:ring-2 focus:ring-primary focus:border-primary transition"></textarea>
            </div>

            <div>
                <label for="keywords" class="block text-sm font-bold text-gray-700 mb-1">Keywords</label>
                <input type="text" id="keywords" placeholder="Comma-separated, e.g. ielts, academic, advanced" class="w-full border border-gray-300 rounded-lg shadow-sm p-3 focus:ring-2 focus:ring-primary focus:border-primary transition">
                <p class="text-xs text-gray-500 mt-1">Helps you find your set later.</p>
            </div>

            <div>
                <label for="folder" class="block text-sm font-bold text-gray-700 mb-1">Folder</label>
                <select id="folder" class="w-full border border-gray-300 rounded-lg shadow-sm p-3 focus:ring-2 focus:ring-primary focus:border-primary transition bg-white">
                    <option>Default</option>
                    <option>IELTS</option>
                    <option>Business English</option>
                    <option>+ Create new folder...</option>
                </select>
            </div>

            <div>
                <label class="block text-sm font-bold text-gray-700 mb-2">Sharing Status</label>
                <div class="space-y-3">
                    <div class="flex items-start p-4 border border-primary rounded-lg bg-primary/5">
                        <input id="status-private" name="status" type="radio" checked class="form-radio h-5 w-5 mt-0.5 text-primary focus:ring-primary/50">
                        <div class="ml-3 text-sm">
                            <label for="status-private" class="font-bold text-gray-800">Private</label>
                            <p class="text-gray-600">Only you can see and study this set.</p>
                        </div>
                    </div>
                    <div class="flex items-start p-4 border border-gray-300 rounded-lg">
                        <input id="status-public-view" name="status" type="radio" class="form-radio h-5 w-5 mt-0.5 text-primary focus:ring-primary/50">
                        <div class="ml-3 text-sm">
                            <label for="status-public-view" class="font-bold text-gray-800">Public - View Only</label>
                            <p class="text-gray-600">Others can find and view your set, but cannot copy it.</p>
                        </div>
                    </div>
                    <div class="flex items-start p-4 border border-gray-300 rounded-lg">
                        <input id="status-public-copy" name="status" type="radio" class="form-radio h-5 w-5 mt-0.5 text-primary focus:ring-primary/50">
                        <div class="ml-3 text-sm">
                            <label for="status-public-copy" class="font-bold text-gray-800">Public - Copyable</label>
                            <p class="text-gray-600">Others can find, view, and copy this set to their own account.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="flex justify-end gap-4 pt-4 border-t border-gray-200">
                <button type="button" class="bg-gray-100 text-gray-700 font-semibold py-2 px-6 rounded-lg hover:bg-gray-200 transition-colors">Cancel</button>
                <button type="submit" class="bg-primary text-white font-semibold py-2 px-6 rounded-lg hover:bg-indigo-700 transition-colors">Create Set</button>
            </div>
        </form>
    </div>

</body>
</html>